# ===== Lumina Backend Environment Variables =====

# Required: Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Upload directory for video files (default: ./uploads)
UPLOAD_DIR=./uploads

# Maximum file upload size in MB (default: 500)
MAX_FILE_SIZE_MB=500

# CORS allowed origins, comma-separated (default: localhost dev servers)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional: Redis URL for job state persistence (default: None — uses in-memory dict)
REDIS_URL=

# Logging level (default: INFO)
LOG_LEVEL=INFO
